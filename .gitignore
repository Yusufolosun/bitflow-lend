# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Environment variables (contains sensitive API keys and secrets)
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
frontend/.env
frontend/.env.*
!frontend/.env.example

# Private keys & mnemonics (never commit these)
*.key
*.pem
*.p12
*mnemonic*
*seed-phrase*
*private-key*
*secret*
*.keystore
*.wallet
*credentials*

# Mainnet credentials (encrypted mnemonics and private keys)
settings/
settings/*.toml

# Deployment plans (may contain node credentials)
# Allow simnet plan and .example templates; ignore everything else
deployments/*.yaml
!deployments/default.simnet-plan.yaml
!deployments/*.example.yaml
deployments/mainnet_*.yaml

# Build outputs
dist/
build/
.cache/
*.tsbuildinfo

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Clarinet
.cache/
contracts/vault-core-deploy.clar

# Mainnet credentials (even encrypted, keep private)
settings/

# Temporary/history files
history.txt

# Logs
*.log
logs/

# OS
Thumbs.db
.DS_Store

# Testing
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp.env

.env.production