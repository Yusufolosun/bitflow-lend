# Network Configuration
VITE_NETWORK=testnet

# -------------------------------------------------------------------
# REQUIRED — the app will not start without this variable set
# -------------------------------------------------------------------
# Smart Contract Address (deployed vault contract)
# Testnet example: ST1M46W6CVGAMH3ZJD3TKMY5KCY48HWAZK1GA0CF0.bitflow-vault-core-v3
# Mainnet example: SP1N3809W9CBWWX04KN3TCQHP8A9GN520BD4JMP8Z.bitflow-vault-core-v3
VITE_CONTRACT_ADDRESS=ST1M46W6CVGAMH3ZJD3TKMY5KCY48HWAZK1GA0CF0.bitflow-vault-core-v3

# API Configuration
VITE_API_URL=https://api.testnet.hiro.so

# Stacks Node Configuration
VITE_STACKS_API_URL=https://api.testnet.hiro.so

# Application Configuration
VITE_APP_NAME=BitFlow Lend
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_LIQUIDATIONS=true
VITE_ENABLE_NOTIFICATIONS=true
